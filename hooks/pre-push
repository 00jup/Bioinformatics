#!/bin/sh
# pre-push hook: ruff로 코드 품질 검사
# 우선순위: venv (Unix 경로 → Windows 경로) → conda

REPO_ROOT="$(git rev-parse --show-toplevel)"
CONDA_ENV="bioinfo"

RUFF=""

# 1순위: venv (Unix)
if [ -f "$REPO_ROOT/.venv/bin/ruff" ]; then
    RUFF="$REPO_ROOT/.venv/bin/ruff"
# 2순위: venv (Windows)
elif [ -f "$REPO_ROOT/.venv/Scripts/ruff.exe" ]; then
    RUFF="$REPO_ROOT/.venv/Scripts/ruff.exe"
# 3순위: conda
elif command -v conda >/dev/null 2>&1; then
    CONDA_BASE="$(conda info --base 2>/dev/null)"
    if [ -f "$CONDA_BASE/envs/$CONDA_ENV/bin/ruff" ]; then
        RUFF="$CONDA_BASE/envs/$CONDA_ENV/bin/ruff"
    elif [ -f "$CONDA_BASE/envs/$CONDA_ENV/Scripts/ruff.exe" ]; then
        RUFF="$CONDA_BASE/envs/$CONDA_ENV/Scripts/ruff.exe"
    fi
fi

if [ -z "$RUFF" ]; then
    echo "⚠ ruff를 찾을 수 없습니다. make init을 먼저 실행하세요."
    exit 1
fi

echo "🔍 코드 포맷 검사 중..."
"$RUFF" format --check src/
FORMAT_EXIT=$?

echo "🔍 린트 검사 중..."
"$RUFF" check src/
LINT_EXIT=$?

if [ $FORMAT_EXIT -ne 0 ] || [ $LINT_EXIT -ne 0 ]; then
    echo ""
    echo "❌ 코드 품질 검사 실패!"
    echo "   포맷 수정: make format"
    echo "   린트 확인: make lint"
    exit 1
fi

echo "✅ 코드 품질 검사 통과!"
exit 0
